  "comments": [
    {
      "id": "com1",
      "targetId": "p1",
      "targetType": "Place",
      "authorId": "u3",
      "content": "Absolutely breathtaking architecture. A must-visit in Casablanca!",
      "parentCommentId": null,
      "likes": 12,
      "createdAt": "2026-03-25T14:35:00Z"
    },
    {
      "id": "com2",
      "targetId": "p1",
      "targetType": "Place",
      "authorId": "u2",
      "content": "Glad you enjoyed it! I highly recommend taking the guided tour inside.",
      "parentCommentId": "com1",
      "likes": 3,
      "createdAt": "2026-03-26T10:00:00Z"
    },
    {
      "id": "com3",
      "targetId": "p2",
      "targetType": "Place",
      "authorId": "u6",
      "content": "Le Jardin Majorelle est un vrai paradis de couleurs. Les bougainvillées et le bleu cobalt, c'est magique.",
      "parentCommentId": null,
      "likes": 25,
      "createdAt": "2026-02-14T12:00:00Z"
    },
    {
      "id": "com4",
      "targetId": "p2",
      "targetType": "Place",
      "authorId": "u7",
      "content": "Venez tôt le matin pour éviter la foule. Le musée Berbère à l'intérieur vaut également le détour.",
      "parentCommentId": null,
      "likes": 18,
      "createdAt": "2026-02-20T09:30:00Z"
    },
    {
      "id": "com5",
      "targetId": "p3",
      "targetType": "Place",
      "authorId": "u7",
      "content": "La médina de Fès est un labyrinthe fascinant. Prenez un guide local, vous ne regretterez pas !",
      "parentCommentId": null,
      "likes": 34,
      "createdAt": "2026-01-30T09:00:00Z"
    },
    {
      "id": "com6",
      "targetId": "p3",
      "targetType": "Place",
      "authorId": "u4",
      "content": "En tant que guide, je confirme : la médina de Fès recèle des trésors cachés à chaque coin de rue.",
      "parentCommentId": "com5",
      "likes": 11,
      "createdAt": "2026-01-31T10:00:00Z"
    },
    {
      "id": "com7",
      "targetId": "p4",
      "targetType": "Place",
      "authorId": "u6",
      "content": "Chefchaouen est la ville la plus photogénique que j'ai visitée. Les ruelles bleues sont à couper le souffle.",
      "parentCommentId": null,
      "likes": 47,
      "createdAt": "2026-02-20T17:00:00Z"
    },
    {
      "id": "com8",
      "targetId": "p7",
      "targetType": "Place",
      "authorId": "u3",
      "content": "Jemaa el-Fna la nuit, avec les fumées des stands de nourriture et les musiciens, c'est une expérience inoubliable.",
      "parentCommentId": null,
      "likes": 29,
      "createdAt": "2026-03-15T20:00:00Z"
    },
    {
      "id": "com9",
      "targetId": "p9",
      "targetType": "Place",
      "authorId": "u6",
      "content": "Les tanneries de Chouara sont spectaculaires vues depuis les terrasses des boutiques de cuir. L'odeur est forte mais ça vaut le coup !",
      "parentCommentId": null,
      "likes": 22,
      "createdAt": "2026-02-28T11:00:00Z"
    },
    {
      "id": "com10",
      "targetId": "p12",
      "targetType": "Place",
      "authorId": "u7",
      "content": "Le meilleur hammam de Marrakech. Le soin à l'huile d'argan est divin. Je réserve à chaque visite.",
      "parentCommentId": null,
      "likes": 15,
      "createdAt": "2026-03-20T16:00:00Z"
    },
    {
      "id": "com11",
      "targetId": "gp1",
      "targetType": "GuideProfile",
      "authorId": "u6",
      "content": "Hajar est une guide exceptionnelle ! Sa connaissance de l'architecture islamique est impressionnante.",
      "parentCommentId": null,
      "likes": 8,
      "createdAt": "2026-03-10T10:00:00Z"
    },
    {
      "id": "com12",
      "targetId": "gp3",
      "targetType": "GuideProfile",
      "authorId": "u7",
      "content": "Sohaila nous a fait découvrir des coins de Chefchaouen que jamais on n'aurait trouvés seuls. Merci !",
      "parentCommentId": null,
      "likes": 19,
      "createdAt": "2026-03-12T14:00:00Z"
    }
  ],

